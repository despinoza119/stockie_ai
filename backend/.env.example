# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_VERSION=0.1.0
APP_DEBUG=true

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG              # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Database ─────────────────────────────────────────────────────────────────
# Matches the defaults in infra/.env.example; update if you override those.
DATABASE_URL=postgresql+asyncpg://stockie:stockie@localhost:5432/stockie_ai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security (added when auth is wired in Sprint 7) ──────────────────────────
# SECRET_KEY=changeme
