# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_VERSION=0.1.0
APP_DEBUG=true

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG              # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Database (added when Alembic/Postgres is wired in Sprint 0 task 3) ────────
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stockie_ai

# ── Redis (added when Celery is wired in Sprint 2) ────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Security (added when auth is wired in Sprint 7) ──────────────────────────
# SECRET_KEY=changeme
